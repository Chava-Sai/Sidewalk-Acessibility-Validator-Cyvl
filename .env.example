# Classifier checkpoint path (local file). If missing, backend tries MODEL_URL.
MODEL_PATH=sidewalk_classifier_fair.pt
MODEL_URL=https://github.com/Chava-Sai/Sidewalk-Acessibility-Validator-Cyvl/releases/latest/download/sidewalk_classifier_fair.pt

# Optional precomputed map-analysis cache to speed cold starts.
SIDEWALK_CACHE_PATH=sidewalk_results_cache.json

# Default AI provider for summary/presence checks: groq or gemini
LLM_PROVIDER=groq

# Llama Vision via Groq (recommended free-first provider)
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_FALLBACK_MODELS=

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_FALLBACK_MODELS=gemini-flash-latest,gemini-2.5-flash-lite

# Frontend API base URL
# VITE_API_BASE_URL=http://localhost:8001
