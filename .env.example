# Classifier checkpoint path (local file)
MODEL_PATH=sidewalk_classifier_fair.pt

# Default AI provider for summary/presence checks: groq or gemini
LLM_PROVIDER=groq

# Groq (recommended free-first provider)
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_FALLBACK_MODELS=meta-llama/llama-4-maverick-17b-128e-instruct

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_FALLBACK_MODELS=gemini-flash-latest,gemini-2.5-flash-lite

# Frontend API base URL
# VITE_API_BASE_URL=http://localhost:8001
